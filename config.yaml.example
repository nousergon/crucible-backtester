# ─────────────────────────────────────────────────────────────────────────────
# DESCRIPTIVE / DOCUMENTATION ONLY
#
# Production reads the live config from alpha-engine-config/backtester/config.yaml
# at runtime (spot_backtest.sh syncs it onto the spot instance at boot).
# Edits to this file affect ONLY:
#   1. New-environment bootstrap (copies this template to config.yaml), and
#   2. Public-repo schema documentation for the backtester's config surface.
#
# Edits here have ZERO effect on the live system. To change a runtime value
# or add a flag that needs to take effect, the change MUST land in
# alpha-engine-config (separate private repo).
# ─────────────────────────────────────────────────────────────────────────────

# Alpha Engine Backtester Configuration
# Copy to config.yaml and customise all values below.
# config.yaml is gitignored and should never be committed.

# S3 bucket for signals and prices
signals_bucket: your-research-bucket

# S3 bucket for backtest output
output_bucket: your-research-bucket
output_prefix: backtest

# Local results directory
results_dir: results

# Portfolio simulation parameters (Mode 2)
init_cash: 1_000_000.0
min_simulation_dates: 5
simulation_fees: 0.001  # 10 bps round-trip

# Simulation realism (Gap #2, #3)
simulation:
  slippage_bps: 10              # basis points per side (entry + exit)
  assume_next_day_fill: true    # shift entry fills to next trading day

# Path to alpha-engine repo root — required for Mode 2 (imports executor.main)
# List as many paths as needed; first existing directory wins.
executor_paths:
  - /path/to/local/alpha-engine        # local dev
  - /home/ec2-user/alpha-engine        # EC2

# Path to alpha-engine-research repo root — used to read current scoring weights
# from config/universe.yaml automatically. First existing path wins.
research_paths:
  - /path/to/local/alpha-engine-research
  - /home/ec2-user/alpha-engine-research

weight_optimizer_min_samples: 30

# Signal quality parameters (Mode 1)
score_thresholds:
  - 60
  - 65
  - 70
  - 75
  - 80
  - 85
  - 90

# Score buckets for accuracy analysis
score_buckets:
  - [60, 70]
  - [70, 80]
  - [80, 90]
  - [90, 100]

# Minimum samples required for a bucket to be reported
min_samples: 30

# Email (AWS SES — sender must be verified in SES)
email_sender: "you@example.com"
email_recipients:
  - "you@example.com"

# research.db — pulled from s3://{signals_bucket}/research.db at run start.
# Override with --db flag for local development (e.g. python backtest.py --db ~/path/to/research.db).
# Do not set this in config.yaml for EC2 — the S3 pull is automatic.

# Path to alpha-engine-predictor repo root — used for predictor-only backtest
predictor_paths:
  - /path/to/local/alpha-engine-predictor
  - /home/ec2-user/alpha-engine-predictor

# Predictor backtest settings (--mode predictor-backtest)
# The predictor-backtest is the PRIMARY param sweep source — it uses the full
# price cache (up to 10y) for statistically robust optimization.
# On the always-on EC2, use max_trading_days: 500 (2y, memory-safe).
# On spot instances, set max_trading_days: 2520 (10y) for full coverage.
predictor_backtest:
  min_trading_days: 252             # 1 year minimum for meaningful Sharpe
  max_trading_days: 2520            # 10y — use spot instance for this
  top_n_signals_per_day: 20
  min_score: 70
  use_full_cache: true              # load 10y S3 cache instead of 2y slim cache
  # Purged + embargoed walk-forward fold scheme for the --walk-forward
  # (point-in-time) path. Defaults below = plan pit-discipline-260515.md §D1;
  # omit the block entirely to use them. Only consulted when walk_forward
  # is on (CLI --walk-forward or top-level `walk_forward: true`).
  walk_forward_params:
    test_window: 21                 # ~1mo; weekly weight-promotion cadence
    min_train: 504                  # ~2y; mirrors predictor WF_MIN_TRAIN_DAYS
    purge: 21                       # canonical label horizon (LdP Ch.7 purge)
    embargo: 2                      # LdP Ch.7 lower bound (predictor has none)
    train_mode: expanding           # matches predictor (d <= train_end)

# Point-in-time-honest predictor backtest (ROADMAP L2371 / Backtester
# Phase 2). DEFAULT false — the single-pass path replays history against
# the current live momentum GBM (look-ahead) and stays the default until
# PR 3's --pit-parity contamination report is reviewed and the flip is
# made manually. Set true here or pass --walk-forward.
walk_forward: false

# ── Param sweep settings ───────────────────────────────────────────────────
# mode: "random" samples from the grid; "grid" runs exhaustive search.
# 60 random trials = 95% confidence of finding a top-5% combination
# (Bergstra & Bengio 2012). Core grid of 1,728 combos fits either mode.
param_sweep_settings:
  mode: random
  max_trials: 60                   # 95% confidence of top-5% for any grid size
  min_trials: 50                   # floor: statistical minimum
  max_trials_cap: 400              # ceiling: cap runtime for large grids
  # seed: 42                       # uncomment for reproducible sweeps

# Core param sweep grid — 6 high-impact parameters (1,728 combinations).
# These are regime-invariant risk/exit rules that affect every trade.
# Extended grid (17 params) available in param_sweep.EXTENDED_GRID.
param_sweep:
  min_score: [65, 70, 75, 80]
  max_position_pct: [0.05, 0.10, 0.15]
  atr_multiplier: [2.0, 2.5, 3.0, 4.0]
  time_decay_reduce_days: [5, 7, 10]
  time_decay_exit_days: [10, 15, 20]
  profit_take_pct: [0.15, 0.20, 0.25, 0.30]

# ── Weight optimizer guardrails ──────────────────────────────────────────────
weight_optimizer:
  default_weights:
    quant: 0.50
    qual: 0.50
  max_single_change: 0.10        # max weight move per update
  min_meaningful_change: 0.03    # min change to trigger update
  blend_factor: 0.20             # conservative: 20% data-driven, 80% current (used as min when ramp active)
  blend_factor_min: 0.20         # blend floor at low sample sizes
  blend_factor_max: 0.50         # blend ceiling at high sample sizes
  blend_ramp_samples: 500        # n_train at which blend reaches max
  confidence_low: 100            # samples threshold for "low" confidence
  confidence_medium: 300         # samples threshold for "medium"/"high"
  horizon_blend:
    beat_spy_10d: 0.50
    beat_spy_30d: 0.50

# ── Executor optimizer guardrails ────────────────────────────────────────────
executor_optimizer:
  min_valid_combos: 5            # minimum sweep combos with sharpe_ratio
  min_sharpe_improvement: 0.10   # best must exceed baseline by 10%+
  drawdown_penalty_weight: 0.50  # penalize max_drawdown in combined ranking score

# ── Stance-sizing optimizer (L300) ───────────────────────────────────────────
# Offline-IC gate for the stance_size_* multipliers (replaces the inert
# predictionless param sweep). Tunes against realized per-stance alpha from
# score_performance; dormant (stance_column_absent) until that migration lands.
# Omit the block to use the institutional defaults below.
stance_sizing_optimizer:
  min_samples_per_stance: 30     # resolved rows per stance before it can move
  min_stance_spread: 0.005       # max−min per-stance alpha must exceed this to act
  min_positive_weeks: 6          # rolling sign-consistency gate
  rolling_weeks: 8
  sensitivity: 2.0               # nudge gain on realized alpha relative to the book
  size_floor: 0.4                # multiplier bounds (match executor stance defaults)
  size_cap: 1.1

# ── Regression monitor / auto-rollback ──────────────────────────────────────
# Post-run gate that auto-rolls-back optimizer config promotions if metrics
# regress vs the saved promotion baseline. Primary risk-adjusted trigger is
# Sortino (skilled-risk evaluator revamp); Sharpe is observability only. Guards
# prevent a degraded/low-power week or a stale/pre-cutover baseline from
# spuriously reverting configs (see the 2026-05-16 spurious-rollback forensic).
regression_monitor:
  accuracy_drop_threshold_pp: 5.0     # rollback if accuracy_10d drops > 5pp
  sortino_drop_threshold_pct: 0.20    # rollback if Sortino drops > 20% (PRIMARY)
  sharpe_drop_threshold_pct: 0.20     # observability only — NOT a trigger
  min_trades_for_rollback: 30         # skip rollback if portfolio total_trades < 30
  min_signals_for_rollback: 30        # skip rollback if resolved signal n < 30
  baseline_max_age_days: 21           # baseline older than this → skip + refresh

# ── Veto threshold analysis ─────────────────────────────────────────────────
veto_analysis:
  confidence_thresholds: [0.50, 0.55, 0.60, 0.65, 0.70, 0.75, 0.80]
  current_default_threshold: 0.60
  min_predictions: 30
  min_veto_decisions: 10
  min_threshold_change: 0.10
  cost_penalty_weight: 0.30
